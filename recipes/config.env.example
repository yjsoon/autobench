# Config for the download + streaming-quantize scripts. Copy to config.env, edit,
# then `source config.env`. No secrets live here (HF_TOKEN goes in a separate,
# gitignored .env). See /tags/self-quantized/ for the full recipe.

# --- Model selection ---------------------------------------------------------
# BF16 REAP source is preferred for low-bit quant (avoids stacking FP8 rounding
# under FP4). The streaming quantizer also accepts block-FP8 sources directly
# (dequantises FP8->BF16 on the fly), so a block-FP8 repo works too.
export SRC_REPO="cerebras/GLM-4.5-Air-REAP-82B-A12B"

# Where the source checkpoint is downloaded (needs fast local NVMe, ~170 GB BF16).
export SRC_DIR="$HOME/models/GLM-4.5-Air-REAP-82B-A12B-bf16"

# Where the NVFP4 W4A16 checkpoint is written (~51 GB for GLM-Air).
export OUT_DIR_STREAM="$HOME/models/GLM-4.5-Air-REAP-82B-A12B-NVFP4A16"

# --- Toolchain / cache -------------------------------------------------------
# Point HF caches at a writable project dir if ~/.cache/huggingface is not yours.
export HF_HOME="$HOME/.hf_home"
# If the Xet backend hangs (some boxes transfer 0 bytes), fall back to HTTPS LFS.
export HF_HUB_DISABLE_XET="1"
